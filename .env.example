# ─── Agent Control Plane — environment template ───
# Copy to .env and fill in. Never commit .env.

# --- Core infra (defaults match docker-compose) ---
DATABASE_URL=postgresql+asyncpg://acp:acp@localhost:5432/acp
# For quick local runs without Postgres, the API falls back to SQLite:
#   DATABASE_URL=sqlite+aiosqlite:///./acp.db
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# --- LLM (Anthropic only, per project decision) ---
ANTHROPIC_API_KEY=
JUDGE_MODEL=claude-haiku-4-5-20251001

# --- Embeddings (local, no key needed) ---
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWT_ISSUER=
CLERK_WEBHOOK_SECRET=

# --- Billing (Stripe test mode) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
ENV=development

# --- Frontend (apps/web/.env.local) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
